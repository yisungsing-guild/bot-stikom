# RAG scoring defaults tuned by sweep
PROGRAM_MATCH_BOOST=0.6
RAG_EXACT_PROGRAM_MATCH_BOOST=1.0
# Disable verbose tracing by default
TRACE_RAG_DECISION=false
FONNTE_LOG_PAYLOAD=true
FONNTE_WEBHOOK_REQUIRE_TOKEN=false
# ===== PRODUCTION ENVIRONMENT =====
# PENTING: Ubah semua nilai placeholder ini dengan nilai yang aman untuk production

# ===== DATABASE: SUPABASE POSTGRESQL PRO =====
# Get from: https://supabase.com â†’ Project Settings â†’ Database â†’ Connection String (Pooler)
# Format: postgresql://postgres.[PROJECT-REF]:[PASSWORD]@aws-*.pooler.supabase.com:<PORT>/postgres
# Note: Supabase Postgres requires SSL; keep `sslmode=require`.
DATABASE_URL="postgresql://USER:PASSWORD@HOST:5432/DATABASE?sslmode=require"

# Welcome message threshold (hours)
WELCOME_THRESHOLD_HOURS=24

# Bot identity (optional)
BOT_NAME="Tiko"
BOT_INTRO_ENABLED=false
BOT_NATURAL_ANSWER_FRAME=true
BOT_SHOW_FOLLOWUP_SUGGESTIONS=false
BOT_INTRO_MESSAGE="Halo Kak, saya Tiko, asisten informasi ITB STIKOM Bali. Saya bisa bantu seputar PMB, rincian biaya, program studi, jadwal pendaftaran, beasiswa, dan informasi kampus."

# Port
PORT=4000
NODE_ENV="production"

# If deployed behind Nginx/Cloudflare, enable this so req.ip uses real client IP.
TRUST_PROXY=true

# Allowed origins for browser-based admin UI/API calls.
# Recommended: set to your admin domain(s), comma-separated.
ALLOWED_ORIGINS="https://admin.your-domain.com"

# Backward-compat escape hatch: if true, allows any Origin in production.
# Not recommended.
# CORS_ALLOW_ANY_ORIGIN=false

# === AUTH & SECURITY ===
# PENTING: Generate JWT secret yang kuat (minimal 64 karakter random)
# Gunakan: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET="CHANGE_ME_TO_RANDOM_64_CHAR_STRING_use_crypto_random_bytes"
JWT_EXPIRES_IN="24h"

# PENTING: Ubah username admin dengan nilai yang unik dan kuat
ADMIN_USERNAME="secure_admin_username_change_this"

# PENTING: ADMIN_PASSWORD bisa berupa:
# - bcrypt hash (direkomendasikan untuk production), atau
# - plain text (boleh, tapi kurang aman)
#
# Cara generate bcrypt hash untuk password admin (jalankan di server):
#   ADMIN_PASSWORD_PLAIN="PasswordKuatKamu" node src/scripts/generateSecrets.js
# lalu copy baris ADMIN_PASSWORD="$2..." ke sini.
ADMIN_PASSWORD="$2b$10$REPLACE_WITH_YOUR_BCRYPT_HASH"

# Optional: Multi-user fallback (works even if DB is temporarily down).
# Prefer ADMIN_USERS for simple demo users. Example:
# ADMIN_USERS="akademik:akademik123:akademik:Akademik;keuangan:keuangan123:keuangan:Keuangan"
ADMIN_USERS=""
# Or use JSON (supports bcrypt via passwordHash):
# ADMIN_USERS_JSON='[{"username":"akademik","password":"...","role":"akademik","displayName":"Akademik"}]'
ADMIN_USERS_JSON=""

# ===== EMAIL / SMTP NOTIFICATIONS =====
# Enable notification emails when training files are uploaded.
# For Gmail, use App Password if your account has 2FA enabled.
SMTP_HOST="smtp.gmail.com"
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER="your.email@gmail.com"
SMTP_PASS="your-app-password"
SMTP_FROM="Tiko Admin <your.email@gmail.com>"
SUPERADMIN_NOTIFICATION_EMAILS="super1@example.com,super2@example.com"
# Optional: use this if you want links in emails to point to your admin panel.
#PUBLIC_BASE_URL="https://admin.your-domain.com"

# ===== CACHE: UPSTASH REDIS (FREE/PRO) =====
# Get from: https://upstash.com â†’ Database â†’ REST API
# Upstash REST API (Recommended untuk serverless)
UPSTASH_REDIS_REST_URL="https://xxxxx.upstash.io"
UPSTASH_REDIS_REST_TOKEN="your-upstash-rest-token"

# Atau gunakan Redis standard (jika punya Redis server sendiri)
# REDIS_URL="redis://localhost:6379"
# REDIS_PASSWORD=""

# Rate limiting config (requests per minute)
RATE_LIMIT_WINDOW_MS=60000
RATE_LIMIT_MAX_REQUESTS=100
RATE_LIMIT_ADMIN_MAX_REQUESTS=50

# Auth-specific rate limit (avoid locking out login during demos)
RATE_LIMIT_AUTH_MAX_REQUESTS=30

# ===== AI ENGINE: OPENAI =====
# Get from: https://platform.openai.com/api-keys
ENABLE_AI=true
ENABLE_RAG=true
AI_PROVIDER="openai"
OPENAI_API_KEY="sk-proj-REPLACE_WITH_YOUR_OPENAI_API_KEY"
OPENAI_MODEL="gpt-5.2"
OPENAI_EMBEDDING_MODEL="text-embedding-3-small"
OPENAI_RAG_MODEL="gpt-5.2"
OPENAI_RAG_TEMPERATURE=0.2
SEMANTIC_RAG_FIRST=true
SEMANTIC_RAG_ONLY=true
SEMANTIC_RAG_TOP_K=16
SEMANTIC_RAG_CANDIDATES=48
SEMANTIC_RAG_CONTEXT_MAX_CHARS=16000
SEMANTIC_RAG_MIN_SCORE=0.18
OPENAI_SEMANTIC_RAG_MODEL=""
OPENAI_SEMANTIC_RAG_MAX_OUTPUT_TOKENS=1200
OPENAI_SEMANTIC_RAG_TEMPERATURE=0.3
OPENAI_SEMANTIC_RAG_TOP_P=0.8

# ===== WEBSITE FALLBACK (NON-AI EXCERPTS) =====
# Jika RAG tidak punya jawaban yang relevan, bot bisa mengambil kutipan dari website resmi:
# https://www.stikom-bali.ac.id/id/
ENABLE_WEB_SEARCH_FALLBACK=true
WEB_SEARCH_SEED_URL="https://www.stikom-bali.ac.id/id/"
WEB_SEARCH_ALLOWLIST="www.stikom-bali.ac.id"

# robots.txt Content-Signal policy:
# - default bot akan "fail-closed" jika tidak ada Content-Signal: search=yes
# - set true untuk tetap mengizinkan (best-effort) bila sinyal tidak ada
WEB_SEARCH_ALLOW_IF_MISSING_SIGNAL=true

# Batasi crawling agar tetap cepat & stabil
WEB_SEARCH_MAX_PAGES=6
WEB_SEARCH_DELAY_MS=100


# === WHATSAPP PROVIDER =====
# Choose one:
# - Meta Cloud API: WHATSAPP_PROVIDER="business"
# - WATI: WHATSAPP_PROVIDER="wati" (recommended) OR set WHATSAPP_API_ENDPOINT containing "wati"
# - Fonnte (free gateway): WHATSAPP_PROVIDER="fonnte" OR set WHATSAPP_API_ENDPOINT containing "fonnte.com"

# --- Fonnte example ---
WHATSAPP_PROVIDER="fonnte"
WHATSAPP_API_ENDPOINT="https://api.fonnte.com"
# Set your Fonnte API token here (required)
WHATSAPP_API_KEY="REPLACE_WITH_YOUR_FONNTE_TOKEN"

# --- WATI mode (example) ---
# WHATSAPP_PROVIDER="wati"
# WHATSAPP_API_ENDPOINT="https://live-mt-server.wati.io/1095849"
# WHATSAPP_API_KEY="<wati_token_here>"

# --- Meta Cloud API mode (if you use Meta Business API) ---
# WHATSAPP_PROVIDER="business"
# WHATSAPP_API_KEY="EAAxxxxx"
# WHATSAPP_PHONE_NUMBER_ID="123456789"
# WHATSAPP_BUSINESS_ACCOUNT_ID="123456789"
# WHATSAPP_APP_SECRET="your-meta-app-secret"

# Shared webhook verify token used by this server (for Meta verify + optional WATI token-in-URL).
WHATSAPP_WEBHOOK_VERIFY_TOKEN="REPLACE_WITH_RANDOM_WEBHOOK_VERIFY_TOKEN"

# Recommended: require token on WATI webhook POST.
WATI_WEBHOOK_REQUIRE_TOKEN=true

# Recommended: protect internal provider webhook.
# Any inbound provider delivery (including WATI forwarder) should include this token.
PROVIDER_WEBHOOK_TOKEN="REPLACE_WITH_RANDOM_PROVIDER_WEBHOOK_TOKEN"

# Public webhook URL for your deployed server
WHATSAPP_WEBHOOK_URL="https://your-public-domain.example/fonnte/webhook"

# Meta Cloud API webhook signature verification.
# Required ONLY if using Meta Cloud API.
# WHATSAPP_APP_SECRET="your-meta-app-secret"

# ===== FILE UPLOAD SECURITY =====
# Max file size in bytes
# 10MB = 10485760 bytes
# 15MB = 15728640 bytes
MAX_FILE_SIZE=15728640

# Recommended allowed types in production.
# Note: Excel (xls/xlsx) is intentionally excluded by default due to upstream `xlsx` advisories.
# If you really need Excel ingestion, explicitly include xls,xlsx and keep EXCEL_* limits below.
ENABLE_EXCEL_UPLOAD=true
ALLOWED_FILE_TYPES="txt,pdf,csv,docx,xls,xlsx,jpg,jpeg,png,gif,webp"

# Excel parser safety limits (only relevant if you enable xls/xlsx)
EXCEL_MAX_SHEETS=10
EXCEL_MAX_OUTPUT_CHARS=2097152

# ===== URL INGEST (training via URL) =====
# Recommended: restrict which domains can be ingested.
TRAINING_URL_ALLOWLIST="www.stikom-bali.ac.id"
URL_INGEST_MAX_REDIRECTS=3
URL_INGEST_FOLLOW_REDIRECTS=true

# ===== WEB TO RAG SYNC =====
# Pakai URL website resmi sebagai training RAG permanen.
# Jika kosong, script akan memakai WEB_SEARCH_SEED_URL/WEB_SEARCH_SEED_URLS di atas.
WEB_RAG_SEED_URLS=""
WEB_RAG_AUTO_SYNC=false       # Railway: set true agar sync berjalan otomatis saat server start
WEB_RAG_AUTO_SYNC_INTERVAL_HOURS=24
WEB_RAG_MODE="sitemap"          # single | sitemap
WEB_RAG_MAX_PAGES=6
WEB_RAG_DELAY_MS=200
WEB_RAG_DIVISION_KEY=""         # kosong/global, atau isi: marketing, admission, academic, finance, student_affairs, career
WEB_RAG_RESPECT_CONTENT_SIGNAL=true
# ===== OCR CONFIGURATION =====
# Enable OCR untuk scan/image to text
ENABLE_OCR=true
OCR_LANGS="eng+ind"        # English + Indonesian
OCR_MAX_PAGES=5            # Max halaman PDF untuk OCR (hemat memory)
OCR_SCALES="1.5,2.0,2.5"  # Comma-separated scales (higher = better but more memory)

# === LOGGING ===
LOG_LEVEL="info"


