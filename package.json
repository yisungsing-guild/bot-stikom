{
  "name": "whatsapp-bot-system",
  "version": "0.1.0",
  "private": true,
  "_comment": "File ini adalah manifest proyek Node.js. Field yang diawali '_' hanyalah untuk dokumentasi lokal (komentar Bahasa Indonesia). Jangan diandalkan sebagai konfigurasi runtime.",
  "main": "src/index.js",
  "scripts": {
    "dev": "node --max-old-space-size=2048 src/index.js",
    "start": "node --max-old-space-size=2048 src/index.js",
    "start:prod": "node --max-old-space-size=4096 src/index.js",
    "build:admin-ui": "npm --prefix admin-ui run build",
    "diag:ocr:deps": "node scripts/debugOcrDeps.js",
    "diag:pdf:text": "node scripts/debugPdfText.js",
    "verify:training:upload": "node scripts/verifyTrainingUpload.js",
    "audit:rag:academic": "node scripts/auditAcademicRag.js",
    "rag:sync-missing": "node scripts/syncMissingRagIndex.js",
    "build:admin-css": "tailwindcss --input admin-panel.input.css --output admin-panel-legacy.css --minify",
    "dev:admin-css": "tailwindcss --input admin-panel.input.css --output admin-panel-legacy.css --watch",
    "build": "npx prisma generate",
    "migrate": "prisma migrate dev --name init",
    "migrate:deploy": "npx prisma migrate deploy",
    "migrate:deploy:prod": "node scripts/prismaMigrateDeploy.js --prod",
    "prisma:generate": "prisma generate",
    "db:check:prod": "node scripts/checkDb.js --prod",
    "telegram:webhook": "node scripts/telegramWebhook.js",
    "postinstall": "node scripts/postinstall.js",
    "generate:secrets": "node src/scripts/generateSecrets.js",
    "create:dummy-rbac-users": "node scripts/createDummyRbacUsers.js",
    "maint:run": "node scripts/maintenanceScheduler.js --immediate",
    "maint:run:dry": "node scripts/maintenanceScheduler.js --immediate --dry-run",
    "maint:scheduler": "node scripts/maintenanceScheduler.js",
    "maint:clean:sessions": "node scripts/clear_session_pending_flags.js --chatId=all",
    "test": "npm run test:unit",
    "rag:web-sync": "node scripts/ingestWebRag.js",
    "rag:audit-ingest": "node scripts/auditRagIngestCoverage.js",
    "answer-quality:weekly": "node scripts/auditAnswerQualityWeekly.js",
    "test:unit": "jest --runInBand --testPathIgnorePatterns=providerRealUat --testPathIgnorePatterns=run21 --testPathIgnorePatterns=providerWebhook --testPathIgnorePatterns=messageExamples --testPathIgnorePatterns=semanticRagEngine --testPathIgnorePatterns=ragEngine --testPathIgnorePatterns=registrationDiscount --testPathIgnorePatterns=parse_fee_numbering --testPathIgnorePatterns=debug_fee_output --testPathIgnorePatterns=bug-audit --testPathIgnorePatterns=productionRuntime --testPathIgnorePatterns=providerRoute --testPathIgnorePatterns=provider_ --testPathIgnorePatterns=feeComparisonEngine --testPathIgnorePatterns=admin --testPathIgnorePatterns=integrationRuntime --testPathIgnorePatterns=ragRetrieval --testPathIgnorePatterns=retrieval --testPathIgnorePatterns=traceRuntime --testPathIgnorePatterns=fonnte --testPathIgnorePatterns=wati --testPathIgnorePatterns=serverRuntime --testPathIgnorePatterns=fileParser --testPathIgnorePatterns=webSearchFallback",
    "test:evidence": "jest --runInBand tests/evidenceSelector.test.js tests/semanticEvidenceSelection.test.js tests/answerPreflightEvaluator.test.js",
    "test:rag": "jest --runInBand tests/ragEngine.test.js tests/semanticRagEngine.test.js tests/registrationDiscount.cases.test.js tests/registrationDiscount.regression.test.js tests/parse_fee_numbering.test.js",
    "test:integration": "jest --runInBand tests/providerWebhook.test.js tests/messageExamples.test.js",
    "test:uat": "jest --runInBand tests/providerRealUat.test.js",
    "test:handles": "jest --runInBand --detectOpenHandles",
    "diagnostic:run21": "node scripts/run21Diagnostic.js"
  },
  "engines": {
    "node": ">=20.0.0"
  },
  "dependencies": {
    "@prisma/client": "^5.22.0",
    "@upstash/redis": "^1.36.2",
    "@whiskeysockets/baileys": "^7.0.0-rc13",
    "adm-zip": "^0.5.10",
    "axios": "^1.13.6",
    "bcrypt": "^6.0.0",
    "bcryptjs": "^3.0.3",
    "compression": "^1.8.1",
    "cors": "^2.8.5",
    "dotenv": "^17.2.4",
    "eventemitter3": "^5.0.0",
    "express": "^4.18.2",
    "express-rate-limit": "^7.1.5",
    "helmet": "^7.1.0",
    "jsonwebtoken": "^9.0.2",
    "mammoth": "^1.12.0",
    "multer": "^1.4.5-lts.1",
    "nodemailer": "^6.10.1",
    "openai": "^4.28.0",
    "pdf-parse": "^1.1.1",
    "pdf2pic": "^3.2.0",
    "pino": "^9.0.0",
    "pino-pretty": "^11.0.0",
    "prisma": "^5.11.1",
    "redis": "^4.6.12",
    "sharp": "^0.33.5",
    "tesseract.js": "^5.0.5",
    "uuid": "^9.0.0",
    "ws": "^8.13.0",
    "xlsx": "^0.18.5"
  },
  "devDependencies": {
    "@tailwindcss/cli": "^4.2.2",
    "jest": "^29.7.0",
    "patch-package": "^8.0.0",
    "supertest": "^6.3.4",
    "tailwindcss": "^4.2.2"
  },
  "prisma": {
    "seed": "node prisma/seed.js"
  }
}
